# Travle configuration template. Copy this file to `.env` and fill in real values.
# `.env` is gitignored (real secrets); at submission it ships as `.env-tajne.zip`.
# Compose reads these; ASP.NET binds the `Section__Key` names over appsettings.json.

# --- Runtime ---
ASPNETCORE_ENVIRONMENT=Development

# --- Host port mappings (host:container) ---
# Container ports are fixed (SQL 1433, API 5121); only the host side is configurable.
SQLSERVER_HOST_PORT=1435
API_HOST_PORT=5121

# --- Database ---
# MSSQL_SA_PASSWORD must satisfy SQL Server policy (>=8 chars, 3 of: upper/lower/digit/symbol)
# and MUST match the Password= in CONNECTION_STRING below.
# In CONNECTION_STRING, Server is the compose service name `travle-sqlserver` on the internal port 1433.
# DB name 230172 = student index without the IB prefix (course requirement).
MSSQL_SA_PASSWORD=Change_Me_Str0ng!
CONNECTION_STRING=Server=travle-sqlserver;Database=230172;User Id=sa;Password=Change_Me_Str0ng!;TrustServerCertificate=True;

# --- JWT ---
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
JWT_ISSUER=https://travle.com
JWT_AUDIENCE=http://travle.com
JWT_DURATION_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7

# --- App ---
# Base URL the Flutter apps target (mobile emulator uses 10.0.2.2, desktop uses localhost).
API_BASE_URL=http://localhost:5121
# Platform commission percentage, snapshotted per payment.
PLATFORM_FEE_PERCENTAGE=10

# --- RabbitMQ ---
# RABBITMQ_HOST = compose service name (internal); *_HOST_PORT / *_MGMT_PORT are host mappings.
RABBITMQ_HOST=travle-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- SMTP (the worker sends email; the API never does) ---
# For the demo, Mailtrap (sandbox) is easiest: it captures mail in a web inbox — nothing reaches real
# people. Fill these with your provider's values. Leave SMTP_HOST empty to disable sending (the worker
# still starts and drains the queue, logging that mail is not configured).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@travle.com
SMTP_FROM_NAME=Travle
SMTP_USE_STARTTLS=true

# --- Reserved for later phases (not yet wired into compose/app) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
